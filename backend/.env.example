APP_NAME=gps-cloud-backend
APP_ENV=dev
HOST=0.0.0.0
PORT=8000

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DB=gps_tracker

DEVICE_OFFLINE_SECONDS=300

# MQTT (EMQX/Mosquitto) - leave MQTT_HOST empty to disable
MQTT_HOST=
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC=gps/upload
MQTT_CLIENT_ID=gps-backend
MQTT_KEEPALIVE=60
MQTT_QOS=1
